# Production Environment Variables
# Copy this file to .env.prod and fill in the actual values
# IMPORTANT: Never commit .env.prod to version control!
# NOTE: Server runs HTTP only - SSL/TLS is handled by Cloudflare

# ===========================================
# Database Configuration
# ===========================================
SPRING_DATASOURCE_URL=jdbc:mysql://35.212.228.226:3306/baby_development
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

# ===========================================
# JWT Configuration
# ===========================================
# Generate a secure secret with: openssl rand -base64 64
JWT_SECRET=your-super-secure-jwt-secret-at-least-64-characters-long-replace-this

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# Use https:// since Cloudflare serves HTTPS to clients
CORS_ALLOWED_ORIGINS=https://app.deanyang.it.com

# ===========================================
# Domain Configuration
# ===========================================
# API:      https://api.deanyang.it.com/
# Kibana:   https://api.deanyang.it.com/kibana/
# Frontend: https://app.deanyang.it.com/
SERVER_DOMAIN=api.deanyang.it.com
FRONTEND_DOMAIN=app.deanyang.it.com

# ===========================================
# Email Configuration (Optional)
# ===========================================
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# ===========================================
# Logging Configuration
# ===========================================
LOGSTASH_ENABLED=true
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
